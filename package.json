    "@vitejs/plugin-react": "^4.3.4",
    "diff": "^7.0.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
